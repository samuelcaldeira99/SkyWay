<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- NAVBAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/navy"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="✈ SkyWay Airlines"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PT | R$"
                android:textColor="#BFDBFE"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- BREADCRUMB -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:background="@color/navy_light"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Início  ›  Buscar Voos"
                android:textColor="@color/navy_med"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- HERO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/navy"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="20dp"
            android:paddingBottom="20dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Para onde você quer voar?"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Os melhores preços para sua próxima viagem"
                android:textColor="#BFDBFE"
                android:textSize="13sp"
                android:gravity="center" />
        </LinearLayout>

        <!-- FORM CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- TABS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="36dp"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/tabIdaVolta"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="Ida e volta"
                        android:gravity="center"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:background="@drawable/tab_selected" />

                    <TextView
                        android:id="@+id/tabSoIda"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="Somente ida"
                        android:gravity="center"
                        android:textSize="12sp"
                        android:textColor="@color/text_mid"
                        android:background="@drawable/tab_unselected" />

                    <TextView
                        android:id="@+id/tabMultiplos"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="Múltiplos"
                        android:gravity="center"
                        android:textSize="12sp"
                        android:textColor="@color/text_mid"
                        android:background="@drawable/tab_unselected" />
                </LinearLayout>

                <!-- LINHA 1: Origem e Destino -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Origem"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark"
                            android:layout_marginBottom="2dp" />

                        <EditText
                            android:id="@+id/etOrigem"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/field_bg"
                            android:hint="Ex: São Paulo (GRU)"
                            android:textSize="13sp"
                            android:textColor="@color/text_dark"
                            android:textColorHint="@color/text_light"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:inputType="text"
                            android:text="São Paulo (GRU)" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Destino"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark"
                            android:layout_marginBottom="2dp" />

                        <EditText
                            android:id="@+id/etDestino"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/field_bg"
                            android:hint="Ex: Rio de Janeiro (GIG)"
                            android:textSize="13sp"
                            android:textColor="@color/text_dark"
                            android:textColorHint="@color/text_light"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:inputType="text" />

                        <TextView
                            android:id="@+id/tvErroDestino"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⚠ Informe o destino"
                            android:textSize="11sp"
                            android:textColor="@color/red"
                            android:visibility="gone" />
                    </LinearLayout>
                </LinearLayout>

                <!-- LINHA 2: Datas -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ida"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark"
                            android:layout_marginBottom="2dp" />

                        <EditText
                            android:id="@+id/etIda"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/field_bg"
                            android:hint="DD/MM/AAAA"
                            android:textSize="13sp"
                            android:textColor="@color/text_dark"
                            android:textColorHint="@color/text_light"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:inputType="date"
                            android:text="15/06/2025" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Volta"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark"
                            android:layout_marginBottom="2dp" />

                        <EditText
                            android:id="@+id/etVolta"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/field_bg"
                            android:hint="DD/MM/AAAA"
                            android:textSize="13sp"
                            android:textColor="@color/text_dark"
                            android:textColorHint="@color/text_light"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:inputType="date"
                            android:text="22/06/2025" />
                    </LinearLayout>
                </LinearLayout>

                <!-- LINHA 3: Passageiros e Classe -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Passageiros"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark"
                            android:layout_marginBottom="2dp" />

                        <Spinner
                            android:id="@+id/spinnerPassageiros"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/field_bg"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Classe"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark"
                            android:layout_marginBottom="2dp" />

                        <Spinner
                            android:id="@+id/spinnerClasse"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:background="@drawable/field_bg"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- BOTÃO BUSCAR -->
                <Button
                    android:id="@+id/btnBuscar"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="BUSCAR VOOS"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:backgroundTint="@color/navy_btn" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- RESULTADOS -->
        <LinearLayout
            android:id="@+id/layoutResultados"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="16dp">

            <!-- Header resultados -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/tvResultadoHeader"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/navy" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Menor preço ▼"
                    android:textSize="12sp"
                    android:textColor="@color/navy_med" />
            </LinearLayout>

            <!-- CARD VOO 1 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardVoo1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LATAM  LA3042"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="4dp"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="06:00 → 07:15  |  1h15  "
                                android:textSize="12sp"
                                android:textColor="@color/text_mid" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Direto"
                                android:textSize="11sp"
                                android:textColor="@color/white"
                                android:background="@drawable/tag_green"
                                android:paddingStart="6dp"
                                android:paddingEnd="6dp"
                                android:paddingTop="2dp"
                                android:paddingBottom="2dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="end|center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="R$ 289"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/green" />

                        <Button
                            android:id="@+id/btnSelecionarVoo1"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:text="Selecionar"
                            android:textSize="12sp"
                            android:textColor="@color/white"
                            android:backgroundTint="@color/navy_btn"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARD VOO 2 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardVoo2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="GOL  G3 1205"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="4dp"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="08:30 → 09:45  |  1h15  "
                                android:textSize="12sp"
                                android:textColor="@color/text_mid" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Direto"
                                android:textSize="11sp"
                                android:textColor="@color/white"
                                android:background="@drawable/tag_green"
                                android:paddingStart="6dp"
                                android:paddingEnd="6dp"
                                android:paddingTop="2dp"
                                android:paddingBottom="2dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="end|center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="R$ 312"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/green" />

                        <Button
                            android:id="@+id/btnSelecionarVoo2"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:text="Selecionar"
                            android:textSize="12sp"
                            android:textColor="@color/white"
                            android:backgroundTint="@color/navy_btn"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARD VOO 3 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardVoo3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AZUL  AD4510"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="4dp"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="11:00 → 13:20  |  2h20  "
                                android:textSize="12sp"
                                android:textColor="@color/text_mid" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="1 escala"
                                android:textSize="11sp"
                                android:textColor="@color/white"
                                android:background="@drawable/tag_orange"
                                android:paddingStart="6dp"
                                android:paddingEnd="6dp"
                                android:paddingTop="2dp"
                                android:paddingBottom="2dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="end|center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="R$ 198"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/green" />

                        <Button
                            android:id="@+id/btnSelecionarVoo3"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:text="Selecionar"
                            android:textSize="12sp"
                            android:textColor="@color/white"
                            android:backgroundTint="@color/navy_btn"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
